{
  "name": "anda-brain",
  "version": "0.6.0",
  "description": "Autonomous Graph Memory for OpenClaw agents via Anda Brain, with automatic memory formation and natural-language recall.",
  "type": "module",
  "main": "src/index.ts",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "files": [
    "src",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "ncu": "npx npm-check-updates -u"
  },
  "keywords": [
    "openclaw",
    "brain",
    "long-term-memory",
    "agent-memory",
    "knowledge-graph"
  ],
  "license": "Apache-2.0",
  "dependencies": {},
  "peerDependencies": {
    "openclaw": ">=2026.3.8"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}